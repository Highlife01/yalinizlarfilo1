rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Araç fotoğrafları — herkes okuyabilir, sadece giriş yapmış kullanıcılar yazabilir
    match /vehicles/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Operasyon fotoğrafları, imzalar ve sözleşmeler — sadece yetkili kullanıcılar
    match /operations/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Müşteri belgeleri (kimlik, ehliyet) — sadece yetkili kullanıcılar
    match /customers/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Diğer tüm yollar — varsayılan olarak kapalı
    match /{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
