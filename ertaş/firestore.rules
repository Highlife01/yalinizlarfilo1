rules_version = '2'; // v2 - secure users

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ─── ERTAŞ FİLO (Şimdilik Public) ───────────────────────────────
    match /ertas_vehicles/{id} {
      allow read, write: if true;
      match /expenses/{expId} { allow read, write: if true; }
    }
    match /ertas_partners/{id} { allow read, write: if true; }
    match /ertas_expenses/{id} { allow read, write: if true; }
    match /ertas_customers/{id} { allow read, write: if true; }
    match /ertas_rentals/{id} { allow read, write: if true; }
    match /ertas_kasa/{id} { allow read, write: if true; }
    match /ertas_alacak/{id} { allow read, write: if true; }
    match /ertas_ortak_hareketler/{id} { allow read, write: if true; }
    // ────────────────────────────────────────────────────────────────

    // ─── Helper functions (Main App) ───────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin'];
    }

    function isOperationOrAdmin() {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'operation'];
    }
    
    // ─── Users collection ───────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // ─── Vehicles ───────────────────────────────────────────────────
    match /vehicles/{vehicleId} {
      allow read: if true; // Public read for website
      allow create, delete: if isAdmin();
      allow update: if isOperationOrAdmin();
    }
    
    // ─── Bookings/Rentals — public form create with schema validation ─
    match /bookings/{bookingId} {
      allow read: if isSignedIn();

      // Public create with strict field + type validation (anti-spam)
      allow create: if
        request.resource.data.keys().hasAll(['customerName', 'customerPhone', 'vehiclePlate', 'startDate']) &&
        request.resource.data.customerName is string &&
        request.resource.data.customerName.size() > 1 &&
        request.resource.data.customerName.size() < 200 &&
        request.resource.data.customerPhone is string &&
        request.resource.data.customerPhone.size() > 5 &&
        request.resource.data.customerPhone.size() < 30 &&
        request.resource.data.vehiclePlate is string &&
        request.resource.data.startDate is string &&
        request.resource.data.keys().size() < 25;

      // Allow operation role to update/delete booking status (delivery/return)
      allow update, delete: if isOperationOrAdmin();
    }
    
    // ─── Vehicle operations (larger limit — base64 signatures + photo arrays) ─
    match /vehicle_operations/{operationId} {
      allow read: if isOperationOrAdmin();
      allow create, update: if isOperationOrAdmin();
      allow delete: if isAdmin();
    }
    
    // ─── Customers ──────────────────────────────────────────────────
    match /customers/{customerId} {
      allow read: if isOperationOrAdmin();
      allow create, update: if isOperationOrAdmin();
      allow delete: if isAdmin();
    }

    // ─── Customer debt / collection records ─────────────────────────
    match /customer_debts/{debtId} {
      allow read: if isOperationOrAdmin();
      allow create, update: if isOperationOrAdmin();
      allow delete: if isAdmin();
    }
    
    // ─── Maintenance records ────────────────────────────────────────
    match /maintenance/{maintenanceId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isOperationOrAdmin();
    }

    // ─── Araç masrafları (vehicle_costs) — Araç Carisi ──────────────
    match /vehicle_costs/{costId} {
      allow read: if isOperationOrAdmin();
      allow create, update: if isOperationOrAdmin();
      allow delete: if isAdmin();
    }
    
    // ─── Settings (admin only) ──────────────────────────────────────
    match /settings/{settingId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ─── Contact messages — public create with validation ───────────
    match /contact_messages/{messageId} {
      allow create: if
        request.resource.data.keys().hasAll(['name', 'email', 'message']) &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 1 &&
        request.resource.data.name.size() < 200 &&
        request.resource.data.email is string &&
        request.resource.data.message is string &&
        request.resource.data.message.size() > 1 &&
        request.resource.data.message.size() < 5000 &&
        request.resource.data.keys().size() < 15;

      allow read, update, delete: if isAdmin();
    }

    // ─── Invoice approved income records ────────────────────────────
    match /income_records/{incomeId} {
      allow read: if isOperationOrAdmin();
      allow write: if isOperationOrAdmin();
    }

    // ─── Tahsilat (payments) ────────────────────────────────────────
    match /payments/{paymentId} {
      allow read: if isOperationOrAdmin();
      allow create: if isOperationOrAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
